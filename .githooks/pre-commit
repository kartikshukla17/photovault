#!/bin/bash

# Prevent committing sensitive files
SENSITIVE_PATTERNS=(
    '\.env'
    '\.pem$'
    'private_key'
    'secret'
    'credentials'
)

STAGED_FILES=$(git diff --cached --name-only)

for pattern in "${SENSITIVE_PATTERNS[@]}"; do
    MATCHES=$(echo "$STAGED_FILES" | grep -iE "$pattern" || true)
    if [ -n "$MATCHES" ]; then
        echo "ERROR: Potentially sensitive file(s) staged for commit:"
        echo "$MATCHES"
        echo ""
        echo "If you're sure this is safe, use: git commit --no-verify"
        exit 1
    fi
done

# Check for hardcoded AWS keys in staged files
if git diff --cached | grep -qE 'AKIA[0-9A-Z]{16}'; then
    echo "ERROR: Possible AWS Access Key detected in staged changes!"
    echo "Remove the key before committing."
    exit 1
fi

exit 0
